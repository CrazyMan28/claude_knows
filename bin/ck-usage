#!/usr/bin/env python3
"""ck-usage — your REAL Claude Code usage.

By default it calls the same server endpoint Claude Code's `/usage` uses
(GET https://api.anthropic.com/api/oauth/usage, with your local OAuth token) and
returns the REAL five-hour and seven-day utilization % and reset times — not an
estimate.

If the token is missing/expired or the call fails, it falls back to a local
estimate computed from ~/.claude/projects/**/*.jsonl (the ccusage approach).

    ck-usage                 # real numbers (compact JSON)
    ck-usage --pretty        # human summary
    ck-usage --estimate      # force the local-JSONL estimate
    ck-usage --root DIR --now ISO   # estimate mode for tests / what-if
"""
import glob
import json
import os
import sys
from datetime import datetime, timedelta, timezone

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, os.path.join(ROOT, "lib"))
from ck_config import load_config, transcript_root  # noqa: E402

USAGE_URL = "https://api.anthropic.com/api/oauth/usage"
OAUTH_BETA = "oauth-2025-04-20"


# ----------------------------- REAL (server) --------------------------------

def _credentials_paths():
    seen = []
    cfg_dir = os.environ.get("CLAUDE_CONFIG_DIR")
    home = os.path.expanduser("~")
    for base in (cfg_dir, os.path.join(home, ".claude"), os.path.join(home, ".claude-secondary")):
        if base and base not in seen:
            seen.append(base)
            yield os.path.join(base, ".credentials.json")


def _read_token():
    for path in _credentials_paths():
        try:
            with open(path, "r", encoding="utf-8") as f:
                oa = (json.load(f) or {}).get("claudeAiOauth") or {}
            if oa.get("accessToken"):
                return oa["accessToken"], oa.get("expiresAt")
        except (OSError, json.JSONDecodeError, KeyError):
            continue
    return None, None


def _plan_tier():
    """Best-effort plan name from .claude.json (no secret)."""
    for path in _credentials_paths():
        cj = os.path.join(os.path.dirname(path), ".claude.json")
        try:
            with open(cj, "r", encoding="utf-8") as f:
                d = json.load(f)
            t = (d.get("oauthAccount") or {}).get("organizationRateLimitTier")
            if t:
                return t
        except (OSError, json.JSONDecodeError):
            continue
    return None


def real_usage(cfg, now):
    token, _ = _read_token()
    if not token:
        return None
    try:
        import urllib.request

        req = urllib.request.Request(
            USAGE_URL,
            headers={
                "Authorization": f"Bearer {token}",
                "anthropic-beta": OAUTH_BETA,
                "User-Agent": "claude_knows/0.1",
                "Content-Type": "application/json",
            },
        )
        with urllib.request.urlopen(req, timeout=8) as resp:
            data = json.loads(resp.read().decode())
    except Exception:
        return None

    fh = data.get("five_hour") or {}
    sd = data.get("seven_day") or {}
    pct = fh.get("utilization")
    resets = fh.get("resets_at")
    resets_in = None
    if resets:
        try:
            dt = datetime.fromisoformat(resets.replace("Z", "+00:00"))
            resets_in = int((dt - now).total_seconds() // 60)
        except ValueError:
            pass

    severity = "normal"
    for lim in data.get("limits") or []:
        if lim.get("kind") == "session":
            severity = lim.get("severity", "normal")

    near_pct = float(cfg.get("usage", {}).get("near_limit_pct", 80))
    return {
        "source": "api",
        "estimate": False,
        "plan": _plan_tier(),
        "five_hour_pct": pct,
        "resets_at": resets,
        "resets_in_min": resets_in,
        "seven_day_pct": sd.get("utilization"),
        "seven_day_resets_at": sd.get("resets_at"),
        "severity": severity,
        "near_limit_pct": near_pct,
        "near_limit": bool(pct is not None and pct >= near_pct),
        "now": now.isoformat(),
    }


# ----------------------------- ESTIMATE (local) -----------------------------

def _parse_ts(ts):
    if not ts:
        return None
    try:
        return datetime.fromisoformat(ts.replace("Z", "+00:00"))
    except (ValueError, AttributeError):
        return None


def _msg_tokens(usage):
    return (
        int(usage.get("input_tokens", 0) or 0)
        + int(usage.get("output_tokens", 0) or 0)
        + int(usage.get("cache_creation_input_tokens", 0) or 0)
        + int(usage.get("cache_read_input_tokens", 0) or 0)
    )


def collect_events(root, since):
    events = []
    scanned = 0
    for path in glob.glob(os.path.join(root, "**", "*.jsonl"), recursive=True):
        try:
            if datetime.fromtimestamp(os.path.getmtime(path), timezone.utc) < since:
                continue
        except OSError:
            continue
        try:
            with open(path, "r", encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if not line or '"usage"' not in line:
                        continue
                    try:
                        obj = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    msg = obj.get("message") or {}
                    usage = msg.get("usage") or obj.get("usage")
                    if not usage:
                        continue
                    ts = _parse_ts(obj.get("timestamp") or msg.get("timestamp"))
                    if ts is None or ts < since:
                        continue
                    scanned += 1
                    events.append((ts, _msg_tokens(usage)))
        except OSError:
            continue
    events.sort(key=lambda e: e[0])
    return events, scanned


def build_blocks(events, window):
    blocks = []
    cur = None
    last_ts = None
    for ts, tok in events:
        if cur is None or (ts - cur["start"]) >= window or (last_ts and (ts - last_ts) >= window):
            cur = {"start": ts, "end": ts, "tokens": 0}
            blocks.append(cur)
        cur["end"] = ts
        cur["tokens"] += tok
        last_ts = ts
    return blocks


def estimate_usage(cfg, root, now, lookback_days):
    ucfg = cfg.get("usage", {})
    window = timedelta(hours=float(ucfg.get("window_hours", 5)))
    near_pct = float(ucfg.get("near_limit_pct", 80))
    since = now - timedelta(days=lookback_days)
    events, scanned = collect_events(root, since)
    blocks = build_blocks(events, window)

    active = blocks[-1] if blocks and now < blocks[-1]["start"] + window else None
    window_tokens = active["tokens"] if active else 0
    resets_at = (active["start"] + window) if active else None
    resets_in = int((resets_at - now).total_seconds() // 60) if resets_at else None

    ceiling_mode = ucfg.get("ceiling_mode", "auto-learn")
    ceiling = ucfg.get("ceiling_tokens")
    if ceiling_mode != "fixed" or not ceiling:
        ceiling = max(max((b["tokens"] for b in blocks), default=0), window_tokens) or None
        ceiling_mode = "auto-learn"
    pct = round(100.0 * window_tokens / ceiling, 1) if ceiling else None

    weekly_tokens = sum(tok for ts, tok in events if ts >= now - timedelta(days=7))
    return {
        "source": "estimate",
        "estimate": True,
        "now": now.isoformat(),
        "five_hour_pct": pct,
        "resets_at": resets_at.isoformat() if resets_at else None,
        "resets_in_min": resets_in,
        "seven_day_pct": None,
        "window_tokens": window_tokens,
        "ceiling_tokens": ceiling,
        "ceiling_mode": ceiling_mode,
        "weekly_tokens": weekly_tokens,
        "messages_scanned": scanned,
        "near_limit_pct": near_pct,
        "near_limit": bool(pct is not None and pct >= near_pct),
    }


# ----------------------------- output ---------------------------------------

def _fmt_reset(r):
    if not r.get("resets_at"):
        return "no active window"
    m = r.get("resets_in_min")
    if m is None:
        return r["resets_at"][11:16] + " UTC"
    hh, mm = divmod(max(m, 0), 60)
    return f"{r['resets_at'][11:16]} UTC (in {hh}h{mm:02d}m)"


def _print_pretty(r):
    real = not r.get("estimate")
    pct = r.get("five_hour_pct")
    bar_n = int((pct or 0) / 5)
    bar = "#" * min(bar_n, 20) + "-" * max(0, 20 - bar_n)
    tag = "REAL (server)" if real else "estimate (local)"
    flag = "  ⚠ NEAR LIMIT" if r.get("near_limit") else ""
    plan = f"  [{r['plan']}]" if r.get("plan") else ""
    print(f"claude_knows usage — {tag}{plan}{flag}")
    print(f"  5-hour   : [{bar}] {pct if pct is not None else '?'}%   resets {_fmt_reset(r)}")
    if r.get("seven_day_pct") is not None:
        sd = r.get("seven_day_resets_at") or ""
        print(f"  7-day    : {r['seven_day_pct']}%   resets {sd[:10]}")
    if r.get("estimate"):
        print(f"  (local estimate: {r.get('window_tokens', 0):,} tok in window, "
              f"ceiling {r.get('ceiling_tokens') or '?'}, {r.get('messages_scanned', 0)} msgs)")


def main():
    argv = sys.argv[1:]
    pretty = "--pretty" in argv
    cfg = load_config()

    now = datetime.now(timezone.utc)
    root = transcript_root()
    lookback_days = 8
    force_estimate = "--estimate" in argv
    for i, a in enumerate(argv):
        if a == "--root" and i + 1 < len(argv):
            root = argv[i + 1]; force_estimate = True
        elif a == "--now" and i + 1 < len(argv):
            now = _parse_ts(argv[i + 1]) or now; force_estimate = True
        elif a == "--lookback-days" and i + 1 < len(argv):
            try:
                lookback_days = int(argv[i + 1])
            except ValueError:
                pass

    result = None
    if not force_estimate:
        result = real_usage(cfg, now)
    if result is None:
        result = estimate_usage(cfg, root, now, lookback_days)

    if pretty:
        _print_pretty(result)
    else:
        print(json.dumps(result))


if __name__ == "__main__":
    main()
